---
import InfoPage from '../components/sections/InfoPage.astro';
import CtaBand from '../components/sections/CtaBand.astro';
---

<InfoPage
	eyebrow="Account"
	title="Forgot Password"
	lede="Platform account recovery will be available when Forjyn app login launches. Until then, contact support for help."
	seoTitle="Forgot Password | Forjyn Technologies"
	seoDescription="Reset or recover access to your Forjyn account."
>
	<p>
		Self-serve password reset is not available on this marketing site yet. When the Forjyn application
		login experience launches, password recovery will be available from the login screen.
	</p>
	<p>In the meantime:</p>
	<ul>
		<li>
			Email
			<a href="mailto:support@forjyn.com">support@forjyn.com</a>
			from the address associated with your account
		</li>
		<li>
			Or
			<a href="/contact">submit a support request</a>
			with subject “Technical support”
		</li>
	</ul>
	<p>
		If you do not have an account yet,
		<a href="/signup">express interest in joining Forjyn</a>
		or
		<a href="/contact#demo">book a demo</a>.
	</p>

	<Fragment slot="after">
		<CtaBand title="Still need access help?" lede="Our team can point you to the right next step.">
			<Fragment slot="actions">
				<a href="/contact" class="btn-primary">Contact Support</a>
				<a href="/login" class="btn-secondary">Back to Log In</a>
			</Fragment>
		</CtaBand>
	</Fragment>
</InfoPage>
