---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import DemoRequestForm from '../components/forms/DemoRequestForm.astro';
import GeneralContactForm from '../components/forms/GeneralContactForm.astro';
import ContactFormScripts from '../components/forms/ContactFormScripts.astro';
import { contactFaqs, contactSeo } from '../data/contact';
---

<BaseLayout title={contactSeo.title} description={contactSeo.description}>
	<PageHero
		eyebrow="Contact"
		title="Let’s Build Better Innovation Infrastructure"
		lede="Whether you are raising capital, investing in startups, managing an innovation community, or supporting founders, we would be pleased to learn more about your goals."
	>
		<Fragment slot="actions">
			<a href="#demo" class="btn-primary">Book a Demo</a>
			<a href="/signup" class="btn-secondary">Sign Up Now</a>
		</Fragment>
	</PageHero>

	<section class="bg-graphite py-16 sm:py-20">
		<div class="container-page grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			<div class="border-t border-line pt-5">
				<h2 class="font-display text-lg font-semibold text-cloud">Book a Demo</h2>
				<p class="mt-2 text-sm leading-relaxed text-slate">
					See how Forjyn supports startup discovery, investor matching, due diligence, events,
					compliance, communications, and ecosystem management.
				</p>
				<a href="#demo" class="link-accent mt-4 inline-flex text-sm">Book a Demo</a>
			</div>
			<div class="border-t border-line pt-5">
				<h2 class="font-display text-lg font-semibold text-cloud">General Inquiries</h2>
				<p class="mt-2 text-sm leading-relaxed text-slate">
					For company, media, partnership, and general questions.
				</p>
				<a href="mailto:info@forjyn.com" class="link-accent mt-4 inline-flex text-sm"
					>info@forjyn.com</a
				>
			</div>
			<div class="border-t border-line pt-5">
				<h2 class="font-display text-lg font-semibold text-cloud">Sales and Partnerships</h2>
				<p class="mt-2 text-sm leading-relaxed text-slate">
					For platform licensing, ecosystem plans, enterprise implementation, or strategic partnerships.
				</p>
				<a href="mailto:sales@forjyn.com" class="link-accent mt-4 inline-flex text-sm"
					>sales@forjyn.com</a
				>
			</div>
			<div class="border-t border-line pt-5">
				<h2 class="font-display text-lg font-semibold text-cloud">Account Support</h2>
				<p class="mt-2 text-sm leading-relaxed text-slate">
					For login assistance, onboarding questions, technical support, or account issues.
				</p>
				<a href="mailto:support@forjyn.com" class="link-accent mt-4 inline-flex text-sm"
					>support@forjyn.com</a
				>
				<a href="/login" class="mt-2 block text-sm text-slate underline-offset-4 hover:underline"
					>Log In</a
				>
			</div>
		</div>
	</section>

	<section id="demo" class="scroll-mt-24 border-y border-line bg-midnight py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
			<div>
				<h2 class="section-heading">Request a Personalized Demonstration</h2>
				<p class="section-lede">
					Complete the form and tell us what you are hoping to accomplish with Forjyn. A demonstration
					can be tailored to your organization and user type.
				</p>
			</div>
			<DemoRequestForm />
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Send Us a Message</h2>
				<p class="section-lede">General inquiries, partnerships, media, and support requests.</p>
			</div>
			<GeneralContactForm />
		</div>
	</section>

	<section class="border-y border-line bg-midnight py-16 sm:py-20">
		<div class="container-page max-w-2xl text-center">
			<h2 class="section-heading">Already Have a Forjyn Account?</h2>
			<p class="mt-4 text-base leading-relaxed text-slate">
				Log in to access your dashboard, manage your profile, review activity, and continue using the
				platform.
			</p>
			<a href="/login" class="btn-primary mt-6">Log In</a>
			<p class="mt-4 text-sm text-slate">
				Forgot your password?
				<a href="/forgot-password" class="link-accent ml-1">Reset Password</a>
			</p>
			<p class="mt-2 text-sm text-slate">
				Do not have an account?
				<a href="/signup" class="link-accent ml-1">Sign Up Now</a>
			</p>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page max-w-3xl">
			<h2 class="section-heading">Contact FAQ</h2>
			<div class="mt-10 space-y-6">
				{
					contactFaqs.map((faq) => (
						<details class="group border-b border-line pb-5">
							<summary class="cursor-pointer list-none font-display text-lg font-semibold text-cloud [&::-webkit-details-marker]:hidden">
								<span class="flex items-center justify-between gap-4">
									{faq.q}
									<span class="text-emerald transition group-open:rotate-45" aria-hidden="true">+</span>
								</span>
							</summary>
							<p class="mt-3 text-sm leading-relaxed text-slate">{faq.a}</p>
						</details>
					))
				}
			</div>
		</div>
	</section>

	<CtaBand
		title="Start Building Better Connections"
		lede="Join Forjyn today or schedule a personalized demonstration to see how the platform can support your innovation community."
	>
		<Fragment slot="actions">
			<a href="#demo" class="btn-primary">Book a Demo</a>
			<a href="/signup" class="btn-secondary">Sign Up Now</a>
		</Fragment>
		<p class="mt-4 text-sm text-slate">
			Existing user?
			<a href="/login" class="ml-1 font-medium text-emerald underline-offset-4 hover:underline"
				>Log In</a
			>
		</p>
	</CtaBand>

	<ContactFormScripts />
</BaseLayout>
