---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';

const title = 'Sign Up | Forjyn Technologies';
const description =
	'Create your Forjyn account and gain access to intelligent tools designed to help startups grow and investors discover stronger opportunities.';

const roles = [
	{
		id: 'startup',
		title: 'Startup',
		body: 'Build your company profile, showcase your opportunity, receive intelligent platform insights, connect with investors, and manage due diligence.',
		cta: 'Join as a Startup',
		href: '/signup?role=startup#continue',
	},
	{
		id: 'investor',
		title: 'Investor',
		body: 'Discover startups, personalize your deal flow, manage opportunities, collaborate during due diligence, and track investment activity.',
		cta: 'Join as an Investor',
		href: '/signup?role=investor#continue',
	},
	{
		id: 'ecosystem',
		title: 'Ecosystem Partner',
		body: 'Support startups, manage referrals, coordinate programs and events, and strengthen your innovation community.',
		cta: 'Join as an Ecosystem Partner',
		href: '/signup?role=ecosystem#continue',
		note: 'Forjyn may require approval or an invitation for certain ecosystem partner accounts.',
	},
];

const selectedRole = Astro.url.searchParams.get('role');
---

<BaseLayout title={title} description={description}>
	<PageHero
		eyebrow="Create Account"
		title="Join the Forjyn Ecosystem"
		lede="Create your account and gain access to intelligent tools designed to help startups grow and investors discover stronger opportunities."
	/>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">How will you use Forjyn?</h2>
				<p class="section-lede">Choose the account type that best describes you.</p>
			</div>

			<div class="mt-12 grid gap-6 lg:grid-cols-3">
				{
					roles.map((role) => {
						const isSelected = selectedRole === role.id;
						return (
							<article
								id={role.id}
								class:list={[
									'flex flex-col rounded-2xl border p-6 sm:p-7',
									isSelected
										? 'border-emerald/40 bg-emerald/10 shadow-glow'
										: 'border-line bg-midnight',
								]}
							>
								<h3 class="font-display text-xl font-semibold text-cloud">{role.title}</h3>
								<p class="mt-3 flex-1 text-sm leading-relaxed text-slate">{role.body}</p>
								{role.note && (
									<p class="mt-4 text-xs leading-relaxed text-slate/80">{role.note}</p>
								)}
								<a href={role.href} class="btn-primary mt-6 justify-center">
									{role.cta}
								</a>
							</article>
						);
					})
				}
			</div>

			{
				selectedRole && (
					<div
						id="continue"
						class="mt-12 scroll-mt-24 rounded-2xl border border-line bg-midnight p-6 sm:p-8"
					>
						<h3 class="font-display text-2xl font-semibold text-cloud">Continue registration</h3>
						<p class="mt-2 text-sm text-slate">
							You selected the{' '}
							<span class="font-semibold text-cloud capitalize">{selectedRole}</span> account type.
							Complete the form below to create your account.
						</p>
						<form class="mt-6 grid gap-4 sm:grid-cols-2" method="post" action="#">
							<input type="hidden" name="role" value={selectedRole} />
							<div>
								<label class="form-label" for="signup-first-name">First Name</label>
								<input class="form-input" id="signup-first-name" name="firstName" type="text" required />
							</div>
							<div>
								<label class="form-label" for="signup-last-name">Last Name</label>
								<input class="form-input" id="signup-last-name" name="lastName" type="text" required />
							</div>
							<div class="sm:col-span-2">
								<label class="form-label" for="signup-email">Work Email</label>
								<input
									class="form-input"
									id="signup-email"
									name="email"
									type="email"
									autocomplete="email"
									required
								/>
							</div>
							<div>
								<label class="form-label" for="signup-password">Password</label>
								<input
									class="form-input"
									id="signup-password"
									name="password"
									type="password"
									autocomplete="new-password"
									required
								/>
							</div>
							<div>
								<label class="form-label" for="signup-organization">Organization</label>
								<input class="form-input" id="signup-organization" name="organization" type="text" />
							</div>
							<div class="sm:col-span-2">
								<button type="submit" class="btn-primary">Create Account</button>
							</div>
						</form>
					</div>
				)
			}

			<div class="mt-12 max-w-2xl border-t border-line pt-8">
				<p class="text-sm text-slate">
					Already have an account?
					<a href="/login" class="link-accent ml-1">Log In</a>
				</p>
				<p class="mt-4 text-xs leading-relaxed text-slate/80">
					By creating an account, you agree to the Forjyn
					<a href="/legal/terms" class="underline-offset-2 hover:underline">Terms of Use</a>
					and
					<a href="/legal/privacy" class="underline-offset-2 hover:underline">Privacy Policy</a>.
				</p>
				<p class="mt-2 text-xs leading-relaxed text-slate/80">
					Investor access to certain opportunities may be subject to identity verification,
					accreditation requirements, and applicable securities laws.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
