---
import BaseLayout from '../layouts/BaseLayout.astro';
import CapabilityList from '../components/sections/CapabilityList.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import {
	homeAiCapabilities,
	homeAudiences,
	homeDealPreview,
	homeDiligenceFeatures,
	homeEventCapabilities,
	homeInvestorCapabilities,
	homeJourney,
	homeSecurityCapabilities,
	homeStartupCapabilities,
} from '../data/home';
---

<BaseLayout preloadLogo>
	{/* Hero — LCP is the H1; avoid opacity:0 entrance animations on critical text */}
	<section class="relative overflow-hidden bg-midnight text-cloud">
		<div class="pointer-events-none absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
		<div
			class="pointer-events-none absolute inset-0 bg-grid-fade bg-[size:48px_48px] opacity-40 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
			aria-hidden="true"
		>
		</div>

		<div class="container-page relative grid min-h-[calc(100vh-4.25rem)] items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:py-20">
			<div>
				<p class="font-display text-sm font-semibold uppercase tracking-[0.22em] text-emerald">
					Forjyn Technologies
				</p>
				<div class="accent-line mt-4 max-w-24"></div>
				<h1 class="mt-5 max-w-xl font-display text-4xl font-bold leading-[1.08] tracking-tight text-cloud sm:text-5xl lg:text-[3.4rem]">
					The Operating System for <span class="text-gradient">Modern Innovation</span>
				</h1>
				<p class="mt-6 max-w-lg text-base leading-relaxed text-slate sm:text-lg">
					Forjyn connects startups, investors, ecosystem partners, and service providers through one
					intelligent technology platform.
				</p>
				<div class="mt-8 flex flex-wrap items-center gap-3">
					<a href="/contact#demo" class="btn-primary">Book a Demo</a>
					<a href="/signup" class="btn-secondary">Sign Up Now</a>
				</div>
				<p class="mt-5 text-sm text-slate">
					Existing user?
					<a href="/login" class="ml-1 font-medium text-emerald underline-offset-4 hover:underline"
						>Log In</a
					>
				</p>
				<p class="mt-10 max-w-md border-t border-line pt-6 text-sm leading-relaxed text-slate">
					One connected platform for discovering, evaluating, supporting, and growing the companies
					shaping the future.
				</p>
			</div>

			<div class="relative" aria-hidden="true">
				<div class="absolute -inset-4 rounded-[2rem] bg-emerald/10 blur-2xl"></div>
				<div class="relative overflow-hidden rounded-2xl border border-line bg-graphite/80 p-5 shadow-glow-border backdrop-blur-sm sm:p-6 motion-safe:animate-float">
					<div class="flex items-center justify-between border-b border-line pb-4">
						<div>
							<p class="text-xs font-medium uppercase tracking-[0.16em] text-slate">Deal Flow</p>
							<p class="mt-1 font-display text-lg font-semibold text-cloud">Personalized Discovery</p>
						</div>
						<span class="metric rounded-full bg-emerald/20 px-3 py-1 text-xs font-semibold text-emerald"
							>94% match</span
						>
					</div>
					<div class="mt-5 space-y-3">
						{
							homeDealPreview.map((item) => (
								<div class="flex items-center justify-between rounded-xl border border-line bg-midnight px-4 py-3 transition hover:shadow-glow">
									<div>
										<p class="text-sm font-semibold text-cloud">{item.name}</p>
										<p class="mt-0.5 text-xs text-slate">{item.meta}</p>
									</div>
									<p class="metric text-sm font-semibold text-emerald">{item.score}</p>
								</div>
							))
						}
					</div>
					<div class="mt-5 grid grid-cols-3 gap-2 border-t border-line pt-4 text-center">
						<div>
							<p class="font-display text-lg font-semibold text-cloud">Match</p>
							<p class="text-[0.7rem] text-slate">Compatibility</p>
						</div>
						<div>
							<p class="font-display text-lg font-semibold text-cloud">Review</p>
							<p class="text-[0.7rem] text-slate">Profiles</p>
						</div>
						<div>
							<p class="font-display text-lg font-semibold text-cloud">Diligence</p>
							<p class="text-[0.7rem] text-slate">Secure rooms</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-midnight py-20 sm:py-24">
		<div class="container-page max-w-3xl">
			<h2 class="section-heading">Innovation Moves Quickly. Your Technology Should Too.</h2>
			<div class="mt-6 space-y-5 text-base leading-relaxed text-slate sm:text-lg">
				<p>
					The innovation ecosystem is filled with opportunity, but the systems supporting it remain
					fragmented.
				</p>
				<p>
					Startups search for investors across disconnected networks. Investors review opportunities
					through spreadsheets, inboxes, referrals, and isolated databases. Ecosystem organizations
					struggle to manage founders, events, programs, referrals, and stakeholder relationships
					across multiple tools.
				</p>
				<p class="font-medium text-cloud">Forjyn brings these workflows together.</p>
				<p>
					Our platform creates a connected environment where startups can become investment-ready,
					investors can discover aligned opportunities, and ecosystem partners can support growth with
					greater efficiency and visibility.
				</p>
			</div>
		</div>
	</section>

	<section class="border-y border-line bg-graphite py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">Built for the People Driving Innovation</h2>
			</div>
			<div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-8">
				{
					homeAudiences.map((item) => (
						<div class="border-t border-line pt-6">
							<h3 class="font-display text-xl font-semibold text-cloud">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate sm:text-base">{item.body}</p>
							<a href={item.href} class="link-accent mt-5 inline-flex text-sm">
								{item.linkLabel}
							</a>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-graphite/50 py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">One Platform. Every Stage of the Opportunity.</h2>
				<p class="section-lede">
					Forjyn supports the journey from initial discovery to deeper evaluation and long-term growth.
				</p>
			</div>
			<ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
				{
					homeJourney.map((step, index) => (
						<li class="relative">
							<span class="font-display text-sm font-semibold text-emerald">
								{String(index + 1).padStart(2, '0')}
							</span>
							<h3 class="mt-2 font-display text-xl font-semibold text-cloud">{step.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate">{step.body}</p>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<section class="bg-midnight py-20 text-cloud sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
					Deal Flow Designed Around You
				</h2>
				<div class="mt-6 space-y-4 text-base leading-relaxed text-slate">
					<p>
						Investors should not have to search through hundreds of irrelevant opportunities to find
						the right company.
					</p>
					<p>
						Forjyn creates a personalized deal discovery experience based on each investor’s stated
						preferences.
					</p>
					<p>
						Investors can browse startup profiles, review compatibility scores, save opportunities,
						express interest, and build a more organized investment pipeline.
					</p>
				</div>
				<a href="/signup?role=investor" class="btn-primary mt-8">Join as an Investor</a>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald">
					Key Investor Capabilities
				</p>
				<CapabilityList items={homeInvestorCapabilities} />
			</div>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 class="section-heading">More Than a Profile. A Platform for Growth.</h2>
				<div class="mt-6 space-y-4 text-base leading-relaxed text-slate">
					<p>
						Forjyn helps startups organize their story, prepare for investor conversations, and
						understand how their opportunity is being received.
					</p>
					<p>
						Founders can build a comprehensive company profile covering their product, market,
						traction, business model, funding, financial information, and team.
					</p>
					<p>
						They can also upload investor materials, monitor interest, review analytics, receive
						AI-supported feedback, and manage requested documents through secure due diligence rooms.
					</p>
				</div>
				<a href="/signup?role=startup" class="btn-primary mt-8">Join as a Startup</a>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald">
					Key Startup Capabilities
				</p>
				<CapabilityList items={homeStartupCapabilities} />
			</div>
		</div>
	</section>

	<section class="border-y border-line bg-midnight py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">Intelligence Built Into the Platform</h2>
				<p class="section-lede">
					Forjyn uses artificial intelligence to help users organize information, identify alignment,
					and make more informed decisions.
				</p>
				<p class="mt-4 text-base leading-relaxed text-slate">
					AI is integrated throughout the platform to assist with evaluation, matching, document
					review, and due diligence. It is designed to support human judgment—not replace it.
				</p>
			</div>
			<div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					homeAiCapabilities.map((item) => (
						<div class="border-t border-line pt-5">
							<h3 class="font-display text-lg font-semibold text-cloud">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate">{item.body}</p>
						</div>
					))
				}
			</div>
			<aside class="mt-12 max-w-3xl rounded-xl border border-line bg-graphite px-5 py-4 text-sm leading-relaxed text-slate">
				<p class="font-semibold text-cloud">Important Notice</p>
				<p class="mt-1.5">
					AI-generated insights are informational tools. They do not constitute investment, financial,
					legal, accounting, or securities advice. Users remain responsible for their own decisions and
					professional due diligence.
				</p>
			</aside>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2 lg:items-start lg:gap-16">
			<div>
				<h2 class="section-heading">Due Diligence Without the Disorganized Email Chains</h2>
				<p class="section-lede">
					Move opportunities from initial interest to structured review inside a secure collaboration
					environment.
				</p>
				<p class="mt-4 text-base leading-relaxed text-slate">
					Forjyn due diligence rooms allow matched startups and investors to exchange information,
					review documents, track outstanding requests, and maintain a clearer record of the process.
				</p>
				<a href="/platform" class="btn-primary mt-8">Explore the Platform</a>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald">
					Due Diligence Features
				</p>
				<CapabilityList items={homeDiligenceFeatures} dotClass="bg-azure" />
			</div>
		</div>
	</section>

	<section class="bg-graphite py-20 text-cloud sm:py-24">
		<div class="container-page max-w-3xl">
			<h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
				Innovation Works Better When the Ecosystem Is Connected
			</h2>
			<div class="mt-6 space-y-4 text-base leading-relaxed text-slate">
				<p>Startup growth requires more than capital.</p>
				<p>
					Founders rely on incubators, accelerators, universities, mentors, legal professionals,
					accountants, consultants, technology providers, corporate partners, and other service
					providers.
				</p>
				<p>
					Forjyn is designed to bring these stakeholders into a more connected environment so startups
					can access relevant support with less friction.
				</p>
				<p>
					The result is a stronger network, better referrals, more visible opportunities, and a clearer
					path from early-stage development to investment and growth.
				</p>
			</div>
		</div>
	</section>

	<section class="bg-midnight py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 class="section-heading">Turn Events Into Meaningful Engagement</h2>
				<p class="section-lede">
					Manage pitch sessions, investor meetings, networking events, workshops, and community
					programming through the same platform your members already use.
				</p>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald">
					Event Capabilities
				</p>
				<CapabilityList items={homeEventCapabilities} />
			</div>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 class="section-heading">Built for Sensitive Information</h2>
				<div class="mt-6 space-y-4 text-base leading-relaxed text-slate">
					<p>
						Investment platforms handle confidential business information, identity documents,
						financial materials, and private communications.
					</p>
					<p>Forjyn is designed with security and controlled access at its foundation.</p>
				</div>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald">
					Security Capabilities
				</p>
				<CapabilityList items={homeSecurityCapabilities} dotClass="bg-violet" />
			</div>
		</div>
	</section>

	<CtaBand
		title="Better Connections Create Better Companies"
		lede="Join a platform designed to help startups grow, investors discover opportunities, and innovation communities work together."
	>
		<Fragment slot="actions">
			<a href="/contact#demo" class="btn-primary">Book a Demo</a>
			<a href="/signup" class="btn-secondary">Sign Up Now</a>
		</Fragment>
		<p class="mt-5 text-sm text-slate">
			<a href="/login" class="font-medium text-emerald underline-offset-4 hover:underline"
				>Log In to Your Account</a
			>
		</p>
	</CtaBand>
</BaseLayout>
