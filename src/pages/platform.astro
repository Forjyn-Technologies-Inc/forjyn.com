const sectionNav = [
	{ href: '#discovery', label: 'Discovery' },
	{ href: '#ai', label: 'AI' },
	{ href: '#due-diligence', label: 'Due Diligence' },
	{ href: '#compliance', label: 'Compliance' },
	{ href: '#admin', label: 'Admin' },
	{ href: '#security', label: 'Security' },
	{ href: '#integrations', label: 'Integrations' },
];
---

<BaseLayout title={title} description={description}>
	<PageHero
		eyebrow="Platform"
		title="Everything Your Innovation Ecosystem Needs in One Platform"
		lede="From account creation and deal discovery to compliance, due diligence, events, communications, and analytics, Forjyn centralizes the workflows that help startup ecosystems operate."
	>
		<Fragment slot="actions">
			<a href="/contact#demo" class="btn-primary">Book a Demo</a>
			<a href="/signup" class="btn-secondary">Sign Up Now</a>
		</Fragment>
	</PageHero>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">A Personalized Experience From the First Login</h2>
				<p class="section-lede">Each user begins with a role-specific onboarding process.</p>
			</div>
			<ul class="capability-list mt-8">
				{
					onboardingCapabilities.map((item) => (
						<li class="capability-item">
							<span class="capability-dot" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
			<div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					roles.map((role) => (
						<div class="border-t border-line pt-5">
							<h3 class="font-display text-lg font-semibold text-cloud">{role.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate">{role.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section id="compliance" class="scroll-mt-24 border-y border-line bg-midnight py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Support for Responsible Platform Access</h2>
				<p class="section-lede">
					Forjyn includes verification workflows that can help administrators manage investor access and
					compliance requirements.
				</p>
				<aside class="mt-8 rounded-xl border border-line bg-graphite px-5 py-4 text-sm leading-relaxed text-slate">
					<p class="font-semibold text-cloud">Important Compliance Notice</p>
					<p class="mt-1.5">
						Availability and implementation of verification features may vary by jurisdiction, customer
						configuration, service provider, and applicable law.
					</p>
					<p class="mt-2">
						Forjyn does not act as a securities dealer, broker, investment adviser, financial
						institution, or legal adviser unless expressly stated and appropriately authorized.
					</p>
				</aside>
			</div>
			<ul class="capability-list content-start">
				{
					complianceCapabilities.map((item) => (
						<li class="capability-item">
							<span class="capability-dot" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section id="discovery" class="scroll-mt-24 bg-midnight py-20 text-cloud sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
					A More Intuitive Way to Explore Startups
				</h2>
				<p class="mt-4 text-base leading-relaxed text-slate">
					Forjyn’s discovery interface makes it easier for investors to review opportunities from
					desktop or mobile devices.
				</p>
			</div>
			<div class="mt-12 grid gap-10 md:grid-cols-3">
				<div>
					<h3 class="font-display text-lg font-semibold">Discovery Actions</h3>
					<ul class="mt-4 space-y-2">
						{
							discoveryActions.map((item) => (
								<li class="flex gap-2 text-sm text-slate">
									<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald" aria-hidden="true" />
									{item}
								</li>
							))
						}
					</ul>
				</div>
				<div>
					<h3 class="font-display text-lg font-semibold">Matching Factors</h3>
					<ul class="mt-4 space-y-2">
						{
							matchingFactors.map((item) => (
								<li class="flex gap-2 text-sm text-slate">
									<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald" aria-hidden="true" />
									{item}
								</li>
							))
						}
					</ul>
				</div>
				<div>
					<h3 class="font-display text-lg font-semibold">Curated Visibility</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate">
						Administrators may use configurable criteria to identify startups for spotlight, showcase,
						featured opportunity sections, and curated pitch sessions.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-14 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Present the Complete Opportunity</h2>
				<p class="section-lede">
					Startup profiles give investors a consistent way to review companies while helping founders
					organize key information.
				</p>
				<ul class="capability-list mt-6">
					{
						profileComponents.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<h2 class="section-heading">Build a Stronger Investor Presentation</h2>
				<p class="section-lede">
					The Startup Studio gives founders tools to create, upload, and organize materials used
					throughout the fundraising process.
				</p>
				<ul class="capability-list mt-6">
					{
						studioTools.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</section>

	<section id="ai" class="scroll-mt-24 border-y border-line bg-midnight py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Structured Insights for More Complete Profiles</h2>
				<p class="section-lede">
					AI evaluations can assess available startup information and produce structured insights.
				</p>
				<p class="mt-4 text-sm leading-relaxed text-slate">
					AI-generated outputs should be reviewed alongside source materials and qualified professional
					advice.
				</p>
			</div>
			<ul class="capability-list content-start">
				{
					evaluationWorkflow.map((item) => (
						<li class="capability-item">
							<span class="capability-dot" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section id="due-diligence" class="scroll-mt-24 bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Secure Collaboration for Serious Opportunities</h2>
				<p class="section-lede">
					When investors and startups move into deeper review, Forjyn creates a dedicated workspace for
					the opportunity.
				</p>
			</div>
			<ul class="capability-list content-start">
				{
					diligenceFeatures.map((item) => (
						<li class="capability-item">
							<span class="capability-dot" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="bg-graphite py-20 text-cloud sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
					Support the Financial Side of Membership and Opportunity Tracking
				</h2>
				<p class="mt-4 text-base leading-relaxed text-slate">
					Forjyn integrates with Stripe to support selected payment functions.
				</p>
				<aside class="mt-8 rounded-xl border border-line bg-graphite px-5 py-4 text-sm leading-relaxed text-slate">
					<p class="font-semibold text-cloud">Financial Transaction Notice</p>
					<p class="mt-1.5">
						The exact processing of investments, securities transactions, custody, transfers,
						subscriptions, and commitments depends on the customer’s configuration, legal structure,
						jurisdiction, and authorized financial service providers.
					</p>
				</aside>
			</div>
			<ul class="space-y-2.5 content-start">
				{
					paymentCapabilities.map((item) => (
						<li class="flex gap-2.5 text-sm text-slate">
							<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="bg-midnight py-20 sm:py-24">
		<div class="container-page grid gap-14 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Bring Your Community Together</h2>
				<p class="section-lede">
					Manage events across the same platform where users discover and evaluate opportunities.
				</p>
				<ul class="capability-list mt-6">
					{
						eventTools.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<h2 class="section-heading">Keep Every Stakeholder Informed</h2>
				<p class="section-lede">
					Forjyn supports communications across email, mobile, and in-platform channels.
				</p>
				<ul class="capability-list mt-6">
					{
						communicationTools.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</section>

	<section class="bg-graphite py-20 sm:py-24">
		<div class="container-page grid gap-14 lg:grid-cols-2">
			<div>
				<h2 class="section-heading">Encourage Meaningful Community Involvement</h2>
				<ul class="capability-list mt-6">
					{
						engagementFeatures.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<h2 class="section-heading">Access Forjyn Wherever Opportunities Happen</h2>
				<p class="section-lede">
					Forjyn supports mobile deployment through Capacitor wrappers for iOS and Android.
				</p>
				<ul class="capability-list mt-6">
					{
						mobileCapabilities.map((item) => (
							<li class="capability-item">
								<span class="capability-dot" aria-hidden="true" />
								{item}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</section>

	<section id="admin" class="scroll-mt-24 border-y border-line bg-midnight py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">Centralized Control Without Complicated Workflows</h2>
				<p class="section-lede">
					The Forjyn administrative suite gives authorized users visibility into platform operations.
				</p>
			</div>
			<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					adminCapabilities.map((item) => (
						<div class="border-t border-line pt-5">
							<h3 class="font-display text-lg font-semibold text-cloud">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate">{item.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section id="security" class="scroll-mt-24 bg-midnight py-20 text-cloud sm:py-24">
		<div class="container-page grid gap-12 lg:grid-cols-2">
			<div>
				<h2 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
					Security at Every Layer
				</h2>
				<p class="mt-4 text-base leading-relaxed text-slate">
					Forjyn is designed to help protect personal, financial, company, and investment-related
					information.
				</p>
				<aside class="mt-8 rounded-xl border border-line bg-graphite px-5 py-4 text-sm leading-relaxed text-slate">
					<p class="font-semibold text-cloud">Security Disclaimer</p>
					<p class="mt-1.5">
						Security controls reduce risk but cannot eliminate every possible threat. Platform users
						and customers are responsible for maintaining appropriate access practices and protecting
						their login credentials.
					</p>
				</aside>
			</div>
			<ul class="space-y-2.5 content-start">
				{
					securityArchitecture.map((item) => (
						<li class="flex gap-2.5 text-sm text-slate">
							<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald" aria-hidden="true" />
							{item}
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section id="integrations" class="scroll-mt-24 bg-graphite py-20 sm:py-24">
		<div class="container-page">
			<div class="max-w-2xl">
				<h2 class="section-heading">Connected to the Tools That Power the Platform</h2>
			</div>
			<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					integrations.map((item) => (
						<div class="border-t border-line pt-5">
							<h3 class="font-display text-lg font-semibold text-cloud">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate">{item.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CtaBand
		title="Experience the Forjyn Platform"
		lede="See how intelligent technology can simplify discovery, evaluation, collaboration, and ecosystem growth."
	>
		<Fragment slot="actions">
			<a href="/contact#demo" class="btn-primary">Book a Demo</a>
			<a href="/signup" class="btn-secondary">Sign Up Now</a>
		</Fragment>
		<p class="mt-4 text-sm text-slate/80">
			Existing user? <a href="/login" class="link-accent">Log In</a>
		</p>
	</CtaBand>
</BaseLayout>
