---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Log In | Forjyn Technologies';
const description =
	'Log in to access your Forjyn account, manage opportunities, review activity, and continue building meaningful connections across the innovation ecosystem.';
---

<BaseLayout title={title} description={description}>
	<section class="relative overflow-hidden bg-mist-50 py-16 sm:py-24">
		<div
			class="pointer-events-none absolute inset-x-0 top-0 h-72 bg-gradient-to-b from-ink-900/[0.04] to-transparent"
			aria-hidden="true"
		>
		</div>
		<div class="container-page relative grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-center">
			<div class="max-w-lg">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent-dark">Account Access</p>
				<h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
					Welcome Back
				</h1>
				<p class="mt-5 text-base leading-relaxed text-ink-700/75">
					Log in to access your Forjyn account, manage opportunities, review activity, and continue
					building meaningful connections across the innovation ecosystem.
				</p>
				<aside class="mt-8 rounded-xl border border-ink-900/10 bg-white px-5 py-4 text-sm leading-relaxed text-ink-700/70">
					<p class="font-semibold text-ink-800">Security Note</p>
					<p class="mt-1.5">
						Forjyn uses secure session management, role-based permissions, encryption, and multi-factor
						authentication where required to help protect your account and sensitive information.
					</p>
				</aside>
			</div>

			<div class="rounded-2xl border border-ink-900/8 bg-white p-6 shadow-panel sm:p-8">
				<form method="post" action="#" class="space-y-4">
					<div>
						<label class="form-label" for="login-email">Email Address</label>
						<input
							class="form-input"
							id="login-email"
							name="email"
							type="email"
							autocomplete="email"
							placeholder="Enter the email address associated with your Forjyn account."
							required
						/>
					</div>
					<div>
						<label class="form-label" for="login-password">Password</label>
						<input
							class="form-input"
							id="login-password"
							name="password"
							type="password"
							autocomplete="current-password"
							placeholder="Enter your password."
							required
						/>
					</div>
					<div class="flex items-center justify-between gap-3">
						<label class="flex items-center gap-2 text-sm text-ink-700/80">
							<input class="form-check" type="checkbox" name="remember" />
							Remember me
						</label>
						<a href="/forgot-password" class="link-accent text-sm">Forgot your password?</a>
					</div>
					<button type="submit" class="btn-primary w-full">Log In</button>
				</form>

				<div class="my-6 flex items-center gap-3">
					<span class="h-px flex-1 bg-ink-900/10"></span>
					<span class="text-xs font-medium uppercase tracking-[0.14em] text-ink-700/45">or</span>
					<span class="h-px flex-1 bg-ink-900/10"></span>
				</div>

				<a
					href="/auth/replit"
					class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-ink-900/12 bg-mist-50 px-5 py-2.5 text-sm font-semibold text-ink-800 transition hover:border-accent/30 hover:bg-white"
				>
					Continue with Replit
				</a>

				<div class="mt-8 border-t border-ink-900/8 pt-6">
					<h2 class="font-display text-lg font-semibold text-ink-900">New to Forjyn?</h2>
					<p class="mt-2 text-sm leading-relaxed text-ink-700/70">
						Create an account to access startup opportunities, investor connections, intelligent
						matching, due diligence tools, and other platform resources.
					</p>
					<a href="/signup" class="btn-secondary mt-4">Sign Up Now</a>
				</div>

				<p class="mt-6 text-sm text-ink-700/65">
					Having trouble accessing your account?
					<a href="/contact" class="link-accent ml-1">Contact Support</a>
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
