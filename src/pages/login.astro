---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Log In | Forjyn Technologies';
const description =
	'Log in to access your Forjyn account, manage opportunities, review activity, and continue building meaningful connections across the innovation ecosystem.';
---

<BaseLayout title={title} description={description} noindex>
	<section class="relative overflow-hidden bg-midnight py-16 sm:py-24">
		<div class="container-page relative grid gap-10 lg:grid-cols-[1fr_0.95fr] lg:items-center">
			<div class="max-w-lg">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald">Account Access</p>
				<div class="accent-line mt-4 max-w-24"></div>
				<h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-cloud sm:text-5xl">
					Welcome Back
				</h1>
				<p class="mt-5 text-base leading-relaxed text-slate">
					Log in to access your Forjyn account, manage opportunities, review activity, and continue
					building meaningful connections across the innovation ecosystem.
				</p>
				<aside class="mt-8 rounded-xl border border-line bg-graphite px-5 py-4 text-sm leading-relaxed text-slate">
					<p class="font-semibold text-cloud">Security Note</p>
					<p class="mt-1.5">
						Forjyn uses secure session management, role-based permissions, encryption, and multi-factor
						authentication where required to help protect your account and sensitive information.
					</p>
				</aside>
			</div>

			<div class="rounded-2xl border border-line bg-graphite p-6 shadow-panel sm:p-8">
				<div class="rounded-xl border border-emerald/25 bg-emerald/10 px-4 py-3 text-sm leading-relaxed text-slate">
					<p class="font-semibold text-cloud">App login is launching soon</p>
					<p class="mt-1.5">
						The Forjyn product login experience is not available on this marketing site yet. Book a
						demo or contact us to get early access updates.
					</p>
				</div>

				<div class="mt-6 flex flex-col gap-3">
					<a href="/contact#demo" class="btn-primary w-full justify-center">Book a Demo</a>
					<a href="/signup" class="btn-secondary w-full justify-center">Express Interest in Signing Up</a>
				</div>

				<div class="mt-8 border-t border-line pt-6">
					<h2 class="font-display text-lg font-semibold text-cloud">New to Forjyn?</h2>
					<p class="mt-2 text-sm leading-relaxed text-slate">
						Create interest in an account to access startup opportunities, investor connections,
						intelligent matching, due diligence tools, and other platform resources.
					</p>
					<a href="/signup" class="btn-secondary mt-4">Sign Up Now</a>
				</div>

				<p class="mt-6 text-sm text-slate">
					Having trouble or need account help?
					<a href="/support" class="link-accent ml-1">Contact Support</a>
				</p>
				<p class="mt-2 text-sm text-slate">
					<a href="/forgot-password" class="link-accent">Forgot password guidance</a>
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
