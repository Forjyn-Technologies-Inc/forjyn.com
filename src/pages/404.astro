---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found | Forjyn Technologies';
const description =
	'The page may have moved, the link may have expired, or the address may be incorrect.';
---

<BaseLayout title={title} description={description}>
	<section class="relative overflow-hidden bg-ink-900 py-24 text-white sm:py-32">
		<div class="pointer-events-none absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
		<div class="container-page relative max-w-2xl text-center">
			<p class="font-display text-sm font-semibold uppercase tracking-[0.22em] text-accent-light">
				404
			</p>
			<h1 class="mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl">
				This Opportunity Could Not Be Found
			</h1>
			<p class="mx-auto mt-5 max-w-lg text-base leading-relaxed text-mist-300/90">
				The page may have moved, the link may have expired, or the address may be incorrect.
			</p>
			<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
				<a href="/" class="btn-primary-on-dark">Return Home</a>
				<a href="/login" class="btn-secondary-on-dark">Log In</a>
			</div>
			<p class="mt-5 text-sm text-mist-400">
				<a href="/contact" class="font-medium text-accent-light underline-offset-4 hover:underline"
					>Contact Support</a
				>
			</p>
		</div>
	</section>
</BaseLayout>
