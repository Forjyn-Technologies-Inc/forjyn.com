---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
	absoluteUrl,
	defaultSeo,
	organizationJsonLd,
	toCanonicalPath,
	websiteJsonLd,
} from '../lib/site/seo';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/** Open Graph / Twitter image path or absolute URL (defaults to brand PNG). */
	ogImage?: string;
	/** Override canonical path (defaults to current pathname). */
	canonicalPath?: string;
	/** When true, ask crawlers not to index this page. */
	noindex?: boolean;
}

const {
	title = defaultSeo.title,
	description = defaultSeo.description,
	ogImage = defaultSeo.ogImagePath,
	canonicalPath,
	noindex = false,
} = Astro.props;

const canonical = absoluteUrl(toCanonicalPath(canonicalPath ?? Astro.url.pathname));
const ogImageUrl = absoluteUrl(ogImage);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		<link rel="canonical" href={canonical} />

		<meta property="og:site_name" content="Forjyn Technologies" />
		<meta property="og:locale" content="en_CA" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={defaultSeo.ogImageAlt} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content={String(defaultSeo.ogImageWidth)} />
		<meta property="og:image:height" content={String(defaultSeo.ogImageHeight)} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={defaultSeo.ogImageAlt} />

		<meta name="theme-color" content={defaultSeo.themeColor} />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<link rel="apple-touch-icon" href="/favicon-96x96.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Sora:wght@600;700&display=swap"
			rel="stylesheet"
		/>

		<script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
	</head>
	<body class="min-h-screen flex flex-col bg-midnight text-cloud">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-brand focus:bg-graphite focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-cloud focus:shadow-glow-border"
		>
			Skip to content
		</a>
		<Header />
		<main id="main-content" class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>
