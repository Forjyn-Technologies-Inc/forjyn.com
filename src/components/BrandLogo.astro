---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

/**
 * Brand mark via Astro Image (optimized WebP/AVIF from src/assets).
 * When a wordmark is shown, the image is decorative (empty alt) because
 * the adjacent text already names the brand; otherwise alt is descriptive.
 */
interface Props {
	/** Pixel size of the mark. */
	size?: number;
	/** Show adjacent wordmark text. */
	showWordmark?: boolean;
	/** Short = “Forjyn Technologies”; full = “Forjyn Technologies Inc.” */
	wordmark?: 'short' | 'full';
	/** Eager + high priority for above-the-fold header logo (LCP-friendly). */
	priority?: boolean;
	class?: string;
}

const {
	size = 32,
	showWordmark = true,
	wordmark = 'short',
	priority = false,
	class: className,
} = Astro.props;

const label =
	wordmark === 'full' ? 'Forjyn Technologies Inc.' : 'Forjyn Technologies';
---

<span class:list={['inline-flex items-center gap-2.5', className]}>
	<Image
		src={logo}
		alt={showWordmark ? '' : 'Forjyn Technologies logo'}
		width={size}
		height={size}
		densities={[1, 2]}
		format="webp"
		loading={priority ? 'eager' : 'lazy'}
		fetchpriority={priority ? 'high' : undefined}
		decoding={priority ? 'sync' : 'async'}
		class="rounded-md object-contain"
		style={`width:${size}px;height:${size}px`}
	/>
	{
		showWordmark &&
			(wordmark === 'full' ? (
				<span class="font-display text-2xl font-semibold tracking-tight text-cloud">{label}</span>
			) : (
				<span class="font-display text-lg font-semibold tracking-tight text-cloud">
					Forjyn <span class="font-medium text-slate">Technologies</span>
				</span>
			))
	}
</span>
