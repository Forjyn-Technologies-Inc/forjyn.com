---
import BrandLogo from './BrandLogo.astro';
import { footerColumns } from '../lib/site/nav';
import { investmentDisclaimer } from '../data/legal';

interface Props {
	/** Show the “Ready to Join” CTA card. */
	showCta?: boolean;
	/** Copyright year override. */
	year?: number;
}

const { showCta = true, year = 2026 } = Astro.props;
---

<footer class="border-t border-line bg-midnight text-slate">
	<div class="container-page py-14 sm:py-16">
		<div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
			<div class="max-w-md">
				<a href="/" class="inline-flex" aria-label="Forjyn Technologies home">
					<BrandLogo size={36} wordmark="full" class="gap-3" />
				</a>
				<p class="mt-3 text-sm leading-relaxed text-slate">
					Connecting startups, investors, ecosystem partners, and service providers through
					intelligent technology.
				</p>
			</div>
			{
				showCta && (
					<div class="card-surface p-6 sm:min-w-[20rem]">
						<p class="font-display text-lg font-semibold text-cloud">Ready to Join Forjyn?</p>
						<div class="mt-4 flex flex-wrap gap-3">
							<slot name="cta">
								<a href="/signup" class="btn-secondary">Sign Up Now</a>
								<a href="/contact#demo" class="btn-primary">Book a Demo</a>
							</slot>
						</div>
					</div>
				)
			}
		</div>

		<div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
			{
				footerColumns.map((column) => (
					<div>
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-emerald">
							{column.title}
						</p>
						<ul class="mt-4 space-y-2.5">
							{column.links.map((link) => (
								<li>
									<a
										href={link.href}
										class="text-sm text-slate transition hover:text-cloud"
									>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="mt-14 border-t border-line pt-8">
			<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate">
				Investment Disclaimer
			</p>
			<div class="mt-4 max-w-4xl space-y-3 text-xs leading-relaxed text-slate/85 sm:text-[0.8125rem]">
				{investmentDisclaimer.map((paragraph) => <p>{paragraph}</p>)}
			</div>
			<p class="mt-8 text-sm text-slate/70">
				© {year} Forjyn Technologies Inc. All rights reserved.
			</p>
		</div>
	</div>
</footer>
