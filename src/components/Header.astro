---
import BrandLogo from './BrandLogo.astro';
import { isActivePath, primaryNav } from '../lib/site/nav';

interface Props {
	/** Override pathname for active-link detection (defaults to current URL). */
	pathname?: string;
}

const { pathname = Astro.url.pathname } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-line bg-midnight/90 backdrop-blur-md">
	<div class="container-page">
		<div class="flex h-16 items-center justify-between gap-4 lg:h-[4.25rem]">
			<a href="/" class="group shrink-0" aria-label="Forjyn Technologies home">
				<BrandLogo size={32} wordmark="short" priority />
			</a>

			<nav class="hidden items-center gap-1 xl:flex" aria-label="Primary">
				{
					primaryNav.map((link) => {
						const isActive = isActivePath(pathname, link.href);
						return (
							<a
								href={link.href}
								class:list={[
									'rounded-brand px-3 py-2 text-sm font-medium transition',
									isActive ? 'text-emerald' : 'text-slate hover:text-cloud',
								]}
								aria-current={isActive ? 'page' : undefined}
							>
								{link.label}
							</a>
						);
					})
				}
			</nav>

			<div class="hidden items-center gap-2 md:flex">
				<slot name="actions">
					<a href="/login" class="btn-ghost">Log In</a>
					<a href="/signup" class="btn-secondary">Sign Up Now</a>
					<a href="/contact#demo" class="btn-primary">Book a Demo</a>
				</slot>
			</div>

			<details class="relative xl:hidden">
				<summary
					class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-brand border border-line bg-graphite text-cloud transition hover:border-emerald/40 hover:shadow-glow [&::-webkit-details-marker]:hidden"
					aria-label="Open main navigation menu"
				>
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" focusable="false">
						<path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
					</svg>
					<span class="sr-only">Menu</span>
				</summary>
				<div
					class="absolute right-0 mt-3 w-[min(100vw-2.5rem,20rem)] rounded-2xl border border-line bg-graphite p-3 shadow-panel"
				>
					<nav class="flex flex-col gap-0.5" aria-label="Mobile">
						{
							primaryNav.map((link) => (
								<a
									href={link.href}
									class="rounded-brand px-3 py-2.5 text-sm font-medium text-cloud hover:bg-midnight hover:text-emerald"
								>
									{link.label}
								</a>
							))
						}
					</nav>
					<div class="mt-3 flex flex-col gap-2 border-t border-line pt-3">
						<slot name="mobile-actions">
							<a href="/login" class="btn-ghost justify-center">Log In</a>
							<a href="/signup" class="btn-secondary justify-center">Sign Up Now</a>
							<a href="/contact#demo" class="btn-primary justify-center">Book a Demo</a>
						</slot>
					</div>
				</div>
			</details>
		</div>
	</div>
</header>
