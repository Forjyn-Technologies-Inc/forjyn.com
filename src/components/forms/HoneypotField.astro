---
/**
 * Hidden honeypot field for contact bots. Leave empty — filled values are rejected server-side.
 */
interface Props {
	id: string;
}

const { id } = Astro.props;
---

<div class="absolute -left-[9999px] h-0 w-0 overflow-hidden" aria-hidden="true">
	<label for={id}>Company website</label>
	<input
		id={id}
		type="text"
		name="company_website"
		tabindex="-1"
		autocomplete="off"
		value=""
	/>
</div>
