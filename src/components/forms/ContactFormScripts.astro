---
/**
 * Contact form client wiring. Bundled module script only — no React islands.
 * Inline capture listener prevents native POST before the module binds.
 */
---

<script is:inline>
	document.addEventListener(
		'submit',
		(event) => {
			const target = event.target;
			if (target instanceof HTMLFormElement && target.hasAttribute('data-contact-form')) {
				event.preventDefault();
			}
		},
		true,
	);
</script>
<script>
	import '../../scripts/contactForms.ts';
</script>
