---
/**
 * Cloudflare Web Analytics — loaded after window load on idle so it stays
 * off the critical path. Pair with dashboard setting
 * “Enable with JS Snippet installation” (not automatic injection).
 *
 * Token is public by design (same value Cloudflare injects into HTML).
 * Script is an external module so CSP can drop script-src 'unsafe-inline'.
 */
const token =
	import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN ?? 'c82e7141441e42f3868dc7c4284f4114';
---

<div id="cf-web-analytics" data-token={token} hidden></div>
<script>
	import '../scripts/cloudflareWebAnalytics.ts';
</script>
