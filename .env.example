# Resend + Cloudflare Workers secrets
#
# Local:
#   1. Copy this file to `.env` and `.dev.vars`
#   2. Fill in real values (Cloudflare local runtime reads `.dev.vars`)
#
# Production (Cloudflare):
#   npx wrangler secret put RESEND_API_KEY
#   npx wrangler secret put RESEND_FROM
#   npx wrangler secret put RESEND_TO
#
# Never commit real secrets.

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="Forjyn <noreply@forjyn.com>"
RESEND_TO=sales@forjyn.com
