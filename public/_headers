# Fingerprinted Astro build output (hashed filenames — safe to cache forever)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Public static brand / icon assets (stable filenames; bump name when replacing)
/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/favicon-96x96.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/web-app-manifest-192x192.png
  Cache-Control: public, max-age=31536000, immutable

/web-app-manifest-512x512.png
  Cache-Control: public, max-age=31536000, immutable

/logo.svg
  Cache-Control: public, max-age=31536000, immutable

# HTML documents keep Cloudflare’s default short TTL
# (public, max-age=0, must-revalidate) so deploys are visible immediately.
# Do not set a catch-all /* Cache-Control here — it would comma-merge with
# the long-lived rules above and confuse browsers.
